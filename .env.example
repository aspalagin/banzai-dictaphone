# Server
DICTAPHONE_HOST=127.0.0.1
DICTAPHONE_PORT=8097
DICTAPHONE_TOKEN=change-me
DICTAPHONE_STT_PROVIDER=yandex_realtime

# Telegram delivery
TELEGRAM_BOT_TOKEN=
DICTAPHONE_TELEGRAM_CHAT_ID=
DICTAPHONE_TG_SEND_AUDIO=1

# Yandex AI Studio Realtime
DICTAPHONE_YANDEX_API_KEY=
DICTAPHONE_YANDEX_FOLDER_ID=
DICTAPHONE_YANDEX_REALTIME_MODEL=speech-realtime-250923
DICTAPHONE_YANDEX_REALTIME_LANGUAGE=ru-RU

# Yandex SpeechKit batch STT v3 (DICTAPHONE_STT_PROVIDER=yandex)
YC_API_KEY=
YC_S3_BUCKET=
YC_S3_KEY_ID=
YC_S3_SECRET_KEY=
DICTAPHONE_YANDEX_STT_MODEL=deferred-general:rc
DICTAPHONE_YANDEX_STT_LANGUAGE=ru-RU
DICTAPHONE_YANDEX_STT_DELETE_OBJECT=1

# Optional: OpenAI Realtime STT
OPENAI_API_KEY=
DICTAPHONE_OPENAI_REALTIME_URL=wss://api.openai.com/v1/realtime
DICTAPHONE_OPENAI_STT_MODEL=gpt-realtime-whisper
DICTAPHONE_OPENAI_STT_LANGUAGE=ru
